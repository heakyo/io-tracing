# Ansible hosts
# Edit the hosts
masternode1:~/repo/io-tracing/ansible # cat inventory/hosts
---------------------------------------------------------------
[myservers]
server ip1 -- (e.g. 10.227.237.21)
server ip2 -- (e.g. 10.227.237.22)
server ip3 -- (e.g. 10.227.237.23)

[myservers:vars]
ansible_user=root
ansible_password=a

# Install Ansible
zypper --no-refresh install -y ansible

# ping all the servers
ansible all -e 'ansible_user=root ansible_password=a' -m ping

# playbook hello world
ansible-playbook playbook/hello_world/hello_world.yml

# Print the variable set by the module set_fact in the ymal file
# 1. use the ansible command
ansible localhost -m include_tasks -a 'file=roles/hello_world/tasks/main.yml'

# 2. use the ansible playbook
ansible-playbook debug_playbook.yml

# 3. use the ad-hoc command
ansible localhost -m include_vars -a 'file=vars.yml'
