5.0.31

# If you do not login the system with the root, docker login first with the current user
# This step is very important, or you will not run the ./startup command
# successfully
docker login pscale.artifactory.cec.lab.emc.com
# enter the user name and password(token)

# Check if QA_PATH is mounted
# Set /etc/fstab
# For remote dev
echo "qalogserver.isilon.com:/ifs/qa /mnt/qalogserver/qa nfs rw,hard,intr,nolock,tcp,vers=3,noauto 0 0" >> /etc/fstab
mkdir /mnt/qalogserver/qa
mount /mnt/qalogserver/qa
df -Th /mnt/qalogserver/qa

# For local
echo "10.124.114.70:/share /mnt/qalogserver_cn nfs rw,tcp,intr,vers=3,bg 0 0" >> /etc/fstab
mkdir /mnt/qalogserver_cn
mount /mnt/qalogserver_cn
df -Th /mnt/qalogserver_cn
------------------------------------------------------------------------------------------------
Filesystem           Type  Size  Used Avail Use% Mounted on
10.124.114.70:/share nfs   422T  1.5T  398T   1% /mnt/qalogserver_cn

# Run the command
./startup.sh B_MAIN_3923_DBG_001

# Login to the docker
docker exec -it container-id bash

# export bin
export PATH=$PATH:/root/bin

# check if QA is installed
echo $QA
-------------------
/usr/local/qa

# Logout the docker
Ctrl + D

# connect the target server with en-condebox
/root/bin/en-condebox 10.124.115.31:7031 9800
or
condebox DURINF510-4 9800


