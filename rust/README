# How to install RUST
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
source ~/.cargo/env
rustc --version
cargo --version
--------------------------------
[root@gold-dust rust (main)]# rustc --version
rustc 1.92.0 (ded5c06cf 2025-12-08)
[root@gold-dust rust (main)]# cargo --version
cargo 1.92.0 (344c4567c 2025-10-21)

# How to run hello world
rustc hello.rs
./hello
