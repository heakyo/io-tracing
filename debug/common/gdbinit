#
# Helper function for printing uipc_clients
#
define print_uipc_client
       set $puc_cl = $arg0
       printf "ipc_client %p (pid %d): {\n", $puc_cl, $puc_cl->pid
       printf "  state: %d\n", $puc_cl->state
       printf "  user sock: %p", ((struct unpcb *)($puc_cl->so->so_pcb))->unp_conn->unp_socket
       printf "kern sock: %p, ", $puc_cl->so
       printf "state %#x, ", $puc_cl->so ? $puc_cl->so->so_state : 0
       printf "overflow? %d\n", $puc_cl->overflowed
       if ($puc_cl->so)
         set $puc_sobuf = $puc_cl->so->so_snd
         printf "  snd_sock: cc %u ", $puc_sobuf.sb_cc
	 printf "hiwat %u ", $puc_sobuf.sb_hiwat
	 printf "mbcnt %u ", $puc_sobuf.sb_mbcnt
	 printf "head %p\n", $puc_sobuf.sb_mb
	 set $puc_sobuf = $puc_cl->so->so_rcv
	 printf "  rcv_sock: cc %u ", $puc_sobuf.sb_cc
	 printf "hiwat %u ", $puc_sobuf.sb_hiwat
	 printf "mbcnt %u ", $puc_sobuf.sb_mbcnt
	 printf "head %p\n", $puc_sobuf.sb_mb
       end
       set $puc_mbcnt = 0
       set $puc_clcnt = 0
       set $puc_mbuf = $puc_cl->inq
       while ($puc_mbuf)
         set $puc_nextmbuf = $puc_mbuf->m_hdr.mh_nextpkt
	 while ($puc_mbuf)
	   if (($puc_mbuf->m_hdr.mh_flags & 1) && ($puc_mbuf->M_dat.MH.MH_dat.MH_ext.ext_type == 1))
	     set $puc_clcnt = $puc_clcnt + 1
	   end
	   set $puc_mbcnt = $puc_mbcnt + 1
	   set $puc_mbuf = $puc_mbuf->m_hdr.mh_next
	 end
	 if ($puc_nextmbuf)
	   set $puc_mbuf = $puc_nextmbuf
	 end
       end
       set $puc_size = 0
       set $puc_mbuf = $puc_cl->inq
       while ($puc_mbuf)
         set $puc_size = $puc_size + $puc_mbuf->m_hdr.mh_len
	 set $puc_mbuf = $puc_mbuf->m_hdr.mh_next
       end
       printf "  inq: %p, ", $puc_cl->inq
       printf "mbcnt: %lu ", $puc_mbcnt
       printf "clcnt: %lu ", $puc_clcnt
       printf "size: %d = ", $puc_size
       printf "len: %d\n", $puc_cl->inq_len
       if ($puc_cl->inq && $puc_cl->inq->m_hdr.mh_len >= sizeof(struct iitp_header))
         set $puc_hdr = (struct iitp_header *)($puc_cl->inq->m_hdr.mh_data)
	 printf "  (blocked on incomplete message "
	 printf "size: %d, ", $puc_hdr->size
	 printf "dst_sid: %d)\n", $puc_hdr->dst_sid
       end
       #session_list
       set $puc_sess = $puc_cl->session_list->slh_first
       if ($puc_sess)
         printf "  session_list: {\n"
	 while ($puc_sess)
	   printf "    { local_sid: %d, ", $puc_sess->local_sid
	   printf "remote_sid: %d, ", $puc_sess->remote_sid
	   printf "remote_devid: %d }", $puc_sess->remote_devid
	   set $puc_sess = $puc_sess->client_link->sle_next
	   if ($puc_sess)
	     printf ",\n"
	   end
	 end
	 printf "  \n}\n"
       end
       #listener_list
       set $puc_list = $puc_cl->listener_list->slh_first
       if ($puc_list)
         printf "  listener_list: { "
	 while ($puc_list)
	   printf "xid: %d", $puc_list->xid
	   set $puc_list = $puc_list->client_link->sle_next
	   if ($puc_list)
	     printf ", "
	   end
	 end
	 printf " }\n"
       end
       printf "}\n"
end

#
# Prints out information about all uipc clients.
# This is a gdb equivalent of sysctl.efs.rbm.uipc.clients
#
define uipc_clients
       if (g_ipc.mounted)
	  set $uc_client = g_ipc.client_list->slh_first
	  while ($uc_client)
	    print_uipc_client $uc_client
	    set $uc_client = $uc_client->link->sle_next
	  end
       else
         printf "g_ipc not mounted!\n"
       end
end

