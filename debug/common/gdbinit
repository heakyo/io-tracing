define find_sysctl
  set $fs_list = &sysctl__children
  set $fs_oidp = 0
  set $fs_idx = 0
  while $fs_idx < $argc
    # gdb allows up to 10 arguments
    if $fs_idx == 0
      set $fs_name = $arg0
    end
    if $fs_idx == 1
      set $fs_name = $arg1
    end
    if $fs_idx == 2
      set $fs_name = $arg2
    end
    if $fs_idx == 3
      set $fs_name = $arg3
    end
    if $fs_idx == 4
      set $fs_name = $arg4
    end
    if $fs_idx == 5
      set $fs_name = $arg5
    end
    if $fs_idx == 6
      set $fs_name = $arg6
    end
    if $fs_idx == 7
      set $fs_name = $arg7
    end
    if $fs_idx == 8
      set $fs_name = $arg8
    end
    if $fs_idx == 9
      set $fs_name = $arg9
    end
    find_sysctl_child $fs_list $fs_name
    set $fs_oidp = $fsc_oidp
    if !$fs_oidp
      loop_break
    end
    set $fs_list = $fs_oidp->oid_arg1
    set $fs_idx = $fs_idx + 1
  end
end
document find_sysctl
	Find a sysctl oid struct. This can be a useful way to get
	to structures which are only accessible through sysctl argument
	pointers.

	This function expects a list of strings which allow it to
	walk the sysctl tree. For example:

		find_sysctl "efs" "journal" "drives"

	However, due to limited array allocation on the gdb console,
	this may not actually work. If you see the error

		Too many array elements

	try copying the strings into temporary variables and
	pass those to the function. For example:

		set $journal = "journal"
		set $drives = "drives"
		find_sysctl "efs" $journal $drives
end

define find_set_fail_points
  set $ffp_efs = "efs"
  set $ffp_fail_point = "fail_point"
  find_sysctl $ffp_efs $ffp_fail_point
  set $ffp_prev_fpptr = 0
  set $ffp_oid = ((struct sysctl_oid_list *) $fs_oidp->oid_arg1)->slh_first
  while $ffp_oid
    set $ffp_fpptr = (struct fail_point *) $ffp_oid->oid_arg1
    # multiple sysctls per fail point, avoid dups
    if ($ffp_fpptr != $ffp_prev_fpptr && $ffp_fpptr->fp_entries)
      print *$ffp_fpptr
    end
    set $ffp_prev_fpptr = $ffp_fpptr
    set $ffp_oid = $ffp_oid->oid_link.sle_next
  end
end

define find_fail_point
  set $ffp_efs = "efs"
  set $ffp_fail_point = "fail_point"
  find_sysctl $ffp_efs $ffp_fail_point $arg0
  if $fs_oidp
    print *(struct fail_point *) $fs_oidp->oid_arg1
  end
end
document find_fail_point
	Find a fail point structure by name by walking the sysctl
	tree. Expects a string. See the find_sysctl documentation
	for limitations.
end

