#
# Helper for print_cmds_graph
#
define print_cmd_decl
	set $pcd_cmd = $arg0
	set $pcd_state = $arg1
	set $pcd_swip = $pcd_cmd->sw_swip
	printf "\""
	print_cmd_name $pcd_cmd
	printf " (%p)\"", $pcd_cmd
	# waiting
	if ($pcd_state == 0)
	  printf "[color=yellow,style=filled,label=\""
	end
	# runnable
	if ($pcd_state == 1)
	  printf "[color=blue,style=filled,label=\""
	end
	# running
	if ($pcd_state == 2)
	  printf "[color=green,style=filled,label=\""
	end
	# done
	if ($pcd_state == 3)
	  printf "[color=purple,style=filled,label=\""
	end
	print_cmd_name $pcd_cmd
	printf " {%p}:\\n", $pcd_cmd
	if ($pcd_cmd->sw_cmd == WC_ABORT)
	  printf "error=%d", $pcd_cmd->sw_cmds.sw_abort_cmd.error
	end

	if ($pcd_cmd->sw_cmd == WC_ALLOC)
	  printf "node=%d,", $pcd_cmd->sw_cmds.sw_alloc_cmd.dd.dd_devid
	  printf "drive=%d,", $pcd_cmd->sw_cmds.sw_alloc_cmd.dd.dd_ldnum
	  printf "blocks=%u", $pcd_cmd->sw_cmds.sw_alloc_cmd.blocks->_v->v_used
	end

	if ($pcd_cmd->sw_cmd == WC_FEC)
	  printf "off=%d, ", $pcd_cmd->sw_cmds.sw_fec_cmd.offset
	  printf "first_lbn=%d, ", $pcd_cmd->sw_cmds.sw_fec_cmd.pg->first_lbn
	  printf "prot="
          set $pcd_prot = $pcd_cmd->sw_cmds.sw_fec_cmd.pg->prot
	  if ($pcd_prot.type == PROTECTION_TYPE_FEC)
	    printf "%d+", $pcd_prot.n
	    printf "%d", $pcd_prot.m
            if $pcd_prot.b > 1
              printf "/%d", $pcd_prot.b
            end
	  end
	  if ($pcd_prot.type == PROTECTION_TYPE_MIRRORING)
	    printf "%dx", $pcd_prot.n
	  end
	  printf "\\ngenerate=%d", $pcd_cmd->sw_cmds.sw_fec_cmd.generate
	end

	if ($pcd_cmd->sw_cmd == WC_READ)
	  set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_read_cmd.sbip_sourceaddr->baddr)
	  print_baddr $pcd_baddr
	  print_cacheidx_field $pcd_cmd->sw_cmds.sw_read_cmd
	  print_promoted_field $pcd_cmd->sw_cmds.sw_read_cmd
	end

	if ($pcd_cmd->sw_cmd == WC_RECONSTRUCT)
	  set $pcd_i = 0
	  while ($pcd_i < $pcd_cmd->sw_cmds.sw_reconstruct_cmd.count)
	    printf "lco=%d ", $pcd_cmd->sw_cmds.sw_reconstruct_cmd.blocks[$pcd_i].lco
	    set $pcd_i = $pcd_i + 1
	  end
	end

	if ($pcd_cmd->sw_cmd == WC_UIOMOVE)
	  printf "lbo=%d.", $pcd_cmd->sw_cmds.sw_uiomove_cmd.lbo
	  printf "%d\\n", $pcd_cmd->sw_cmds.sw_uiomove_cmd.sbip_storage->lbn
	  set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_uiomove_cmd.sbip_storage->baddr)
	  print_baddr $pcd_baddr
	  print_flags_field $pcd_cmd->sw_cmds.sw_uiomove_cmd.sbip_storage
	end

	if ($pcd_cmd->sw_cmd == WC_WRITE)
	  if ($pcd_cmd->sw_cmds.sw_write_cmd.sbip_destaddr->baddr.devid != 0)
	    printf "s: "
	    set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_write_cmd.sbip_storage->baddr)
	    print_baddr $pcd_baddr
	    print_flags_field $pcd_cmd->sw_cmds.sw_write_cmd.sbip_storage
	    printf "\\nd: "
	    set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_write_cmd.sbip_destaddr->baddr)
	    print_baddr $pcd_baddr
	    print_flags_field $pcd_cmd->sw_cmds.sw_write_cmd.sbip_destaddr
	  end
	end


	if ($pcd_cmd->sw_cmd == WC_WRITE_UIO_ZERO)
	  printf "lbn=0x%lx", $pcd_cmd->sw_cmds.sw_write_uio_cmd.lbn
	  if ($pcd_cmd->sw_cmds.sw_write_uio_cmd.sbip_destaddr->baddr.devid != 0)
	    printf "\\n"
	    set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_write_uio_cmd.sbip_destaddr->baddr)
	    print_baddr $pcd_baddr
	  end
	end

	if ($pcd_cmd->sw_cmd == WC_ZERO_READ)
	  set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_read_cmd.sbip_sourceaddr->baddr)
	  printf "baddr="
	  print_baddr $pcd_baddr
	  printf "cacheidx=0x%lx", $pcd_cmd->sw_cmds.sw_read_cmd.cacheidx.r
	end

	init-if-undefined $TARGET_VERSION = osrevision
	if ($TARGET_VERSION < $HABANERO_VERSION)
	  if ($pcd_cmd->sw_cmd == WC_WRITE_UIO)
	    printf "lbn=0x%lx", $pcd_cmd->sw_cmds.sw_write_uio_cmd.lbn
	    if ($pcd_cmd->sw_cmds.sw_write_uio_cmd.sbip_destaddr->baddr.devid != 0)
	      printf "\\n"
	      set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_write_uio_cmd.sbip_destaddr->baddr)
	      print_baddr $pcd_baddr
	      print_flags_field $pcd_cmd->sw_cmds.sw_write_cmd.sbip_destaddr
	    end
	  end

	  if ($pcd_cmd->sw_cmd == WC_XFER)
	    printf "s: "
	    set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_xfer_cmd.sbip_storage->baddr)
	    print_baddr $pcd_baddr
	    printf "\\nd: "
	    set $pcd_baddr = & ($pcd_cmd->sw_cmds.sw_xfer_cmd.sbip_destaddr->baddr)
	    print_baddr $pcd_baddr
	  end
	end

	printf "\\nstate="
	if ($pcd_state == 0)
	  printf "WAITING"
	end
	if ($pcd_state == 1)
	  printf "RUNNABLE"
	end
	if ($pcd_state == 2)
	  printf "RUNNING"
	end
	if ($pcd_state == 3)
	  printf "DONE"
	end

	if ($TARGET_VERSION < $HABANERO_VERSION)
	  if ($pcd_swip->expensive_checks)
	    printf ", sw_number=%d", $pcd_cmd->sw_number
	  end
	end
	printf "\"];\n"
end

##############################
# Function: print_cmds_graph #
##############################
#
# Awesome utility function for BSW debugging. This one takes a pointer to a
# struct safe_write_cmds (typically swip->cmds or swip->snap_cmds) and prints
# the entire commands graph in dotty format. Copy/paste into a .dot file and
# run dotty to get a visualization of the safe write graph. Output is in the
# same format as sysctl efs.bam.dump_last_write_plan.
#
# Arguments:
# arg0 - pointer to a struct safe_write_cmds (swip->cmds or swip->snap_cmds)
#

define print_cmds_graph
	set $pcg_cmds = $arg0
	set $pcg_state = 0
	printf "digraph new_write {\n"
	set $pcg_cmd = $pcg_cmds->swc_waiting->tqh_first
	while ($pcg_cmd != 0)
	  print_cmd_decl $pcg_cmd $pcg_state
	  print_cmd_waiters $pcd_cmd
	  set $pcg_cmd = $pcg_cmd->next.tqe_next
	end

	set $pcg_state = 1

	init-if-undefined $TARGET_VERSION = osrevision
	if ($TARGET_VERSION < $HABANERO_VERSION)
	  set $pcg_pri = 0
	  while ($pcg_pri < NUM_ENG_PRIORITIES)
	    set $pcg_cmd = $pcg_cmds->swc_runnable[$pcg_pri]->tqh_first
	    while ($pcg_cmd != 0)
	      print_cmd_decl $pcg_cmd $pcg_state
	      print_cmd_waiters $pcd_cmd
	      set $pcg_cmd = $pcg_cmd->next.tqe_next
	    end
	    set $pcg_pri = $pcg_pri + 1
	  end
	else
	  set $pcg_cmd = $pcg_cmds->swc_runnable->tqh_first
	    while ($pcg_cmd != 0)
	      print_cmd_decl $pcg_cmd $pcg_state
	      print_cmd_waiters $pcd_cmd
	      set $pcg_cmd = $pcg_cmd->next.tqe_next
	  end
	end

	set $pcg_state = 2
	set $pcg_cmd = $pcg_cmds->swc_running->tqh_first
	while ($pcg_cmd != 0)
	  print_cmd_decl $pcg_cmd $pcg_state
	  print_cmd_waiters $pcd_cmd
	  set $pcg_cmd = $pcg_cmd->next.tqe_next
	end
	set $pcg_state = 3
	set $pcg_cmd = $pcg_cmds->swc_done->tqh_first
	while ($pcg_cmd != 0)
	  print_cmd_decl $pcg_cmd $pcg_state
	  print_cmd_waiters $pcd_cmd
	  set $pcg_cmd = $pcg_cmd->next.tqe_next
	end
	printf "}\n"
end

