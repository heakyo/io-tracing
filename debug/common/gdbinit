#
# Walk of allocated memory in a uma zone.
#

define _uma_slab_next_free
	set $umsnf_slab=$arg0
	set $umsnf_pos=$arg1
	set $umsnf_keg=$arg2

	if ($umsnf_keg->uk_flags & 0x0400) # UMA_ZONE_REFCNT
		set $umsnf_ret=((uma_slabrefcnt_t)$umsnf_slab)->um_freelist[$umsnf_pos].us_item
	else
		set $umsnf_ret=$umsif_slab->um_freelist[$umsnf_pos].us_item
	end
end

define _uma_slab_is_free
	set $umsif_slab=$arg0
	set $umsif_ipos=$arg1
	set $umsif_keg=$arg2
	set $umsif_ret=0
	set $umsif_count=$umsif_slab->us_freecount

	set $umsif_fpos = $umsif_slab->us_firstfree
	while ($umsif_fpos != $umsif_ipos && $umsif_count > 0)
		set $umsif_count=$umsif_count-1
		_uma_slab_next_free($umsif_slab, $umsif_fpos, $umsif_keg)
		$umsif_fpos=$umsnf_ret
	end

	if ($umsif_count > 0)
		set $umsif_ret=1
	end
end

define _uma_bucket_is_free
	set $umbif_bucket=$arg0
	set $umbif_item=$arg1
	set $umbif_ret=0

	set $umbif_pos=0
	while(!$umbif_ret && $umbif_pos < $umbif_bucket->ub_cnt)
		if ($umbif_item == $umbif_bucket->ub_bucket[$umbif_pos])
			set $umbif_ret=1
		end
		set $umbif_pos=$umbif_pos+1
	end
end

define _uma_cache_is_free
	set $umcif_zone=$arg0
	set $umcif_item=$arg1
	set $umcif_ret=0

	set $umcif_bucket=$umcif_zone->uz_full_bucket.lh_first
	while ($umcif_bucket && !$umcif_ret)
		_uma_bucket_is_free($umcif_bucket, $umcif_item)
		if ($umbif_ret)
			set $umcif_ret=$umbif_ret
		end
		set $umcif_bucket=$umcif_bucket->ub_link.le_next
	end

	set $umcif_cpu=0
	while (!$umcif_ret && $umcif_cpu < mp_ncpus)
		_uma_bucket_is_free(&$umcif_zone->uz_cpu[$umcif_cpu].uc_freebucket)
		if ($umbif_ret)
			set $umcif_ret=1
		else
			_uma_bucket_is_free(&$umcif_zone->uz_cpu[$umcif_cpu].uc_allocbucket)
			if ($umbif_ret)
				set $umcif_ret=1
			end
		end
	end
end

define _umawalk_advance
	set $umw_ret=(void *)0
	if ($umw_slab)
		set $umw_slab_pos=$umw_slab_pos+1
		if ($umw_slab_pos == $umw_keg->uk_ipers)
			set $umw_slab=$umw_slab->us_head.us_type._us_link.lh_next
			set $umw_slab_pos = 0
			if (!$umw_slab && $umw_part_slab)
				set $umw_slab=$umw_keg->uk_full_slab.lh_first
				set $umw_part_slab=0
			end
		end
	end
end

define umawalk_next
	set $umw_checked=0
	_umawalk_advance()
	while ($umw_slab && !$umw_checked)
		set $umw_checked=1
		if ($umw_part_slab)
			_uma_slab_is_free($umw_slab, $umw_slab_pos, $umw_keg)
			if ($umsif_ret)
				set $umw_checked=0
			end
		end
		if ($umw_checked)
			set $umw_item=(void*)($umw_slab->us_data + $umw_keg->uk_rsize * $umw_slab_next_pos)
			_uma_cache_is_free($umw_zone, $umw_ret)
			if ($umcif_ret)
				set $umw_checked=0
			end
		end
		if (!umw_checked)
			_umawalk_advance()
		end
	end
	if ($umw_slab)
		set $umw_ret=$umw_item
	else
		set $umw_ret=(void*)0
	end
end

define umawalk_start
	set $umw_zone=$arg0
	set $umw_keg=$umw_zone->uz_keg
	set $umw_part_slab=1
	set $umw_slab=$umw_keg->uk_part_slab.lh_first
	set $umw_slab_pos=-1
	umawalk_next()
end

