##################################
# Function: gdb_memcmp           #
##################################

define gdb_memcmp
	set $gdbm_p1 = (const uint8_t *) $arg0
	set $gdbm_p2 = (const uint8_t *) $arg1
	set $gdbm_pos = 0
	set $gdbm_len = $arg2
	set $gdbm_ret = 0

	while !$gdbm_ret && $gdbm_len > $gdbm_pos
		if $gdbm_p1[$gdbm_pos] != $gdbm_p2[$gdbm_pos]
			if $gdbm_p1[$gdbm_pos] > $gdbm_p2[$gdbm_pos]
				set $gdbm_ret = 1
			else
				set $gdbm_ret = -1
			end
		end

		set $gdbm_pos = $gdbm_pos + 1
	end
end

##################################
# Function: hash_find_entry      #
##################################
#
# Returns pointer to matching hash element
#
# Arguments:
# arg0 - pointer to hash
# arg1 - pointer to key to match

define hash_set_bucket_entry
	if $hfe_hash->num_buckets >= 2 * $hfe_buckets_per_page
		set $hfe_chain = &$hfe_hash->storage.pages[$hfe_bucket/$hfe_buckets_per_page][$hfe_bucket & ($hfe_buckets_per_page - 1)]
	else
		set $hfe_chain = &$hfe_hash->storage.chains[$hfe_bucket]
	end

	set $hfe_entry = $hfe_chain->slh_first

	if $hfe_entry
		set $hfe_entry_key = (const uint8_t *) $hfe_entry + $hfe_hash->key_offset
	end
end

define hash_iter_init
	set $hfe_hash = $arg0

	get_page_size
	set $hfe_buckets_per_page = $global_page_size / sizeof(struct isi_hash_chain)
	set $hfe_bucket = 0

	hash_set_bucket_entry
	if !$hfe_entry
		hash_iter_next
	end
end

define hash_iter_next
	if $hfe_entry
		set $hfe_entry = $hfe_entry->bucket_link.sle_next
		if $hfe_entry
			set $hfe_entry_key = (const uint8_t *) $hfe_entry + $hfe_hash->key_offset
		end
	end
	while !$hfe_entry && $hfe_bucket < $hfe_hash->num_buckets
		set $hfe_bucket = $hfe_bucket + 1
		if $hfe_bucket < $hfe_hash->num_buckets
			hash_set_bucket_entry
		end
	end
end

define hash_find_entry
	set $hfe_key = $arg1
	set $hfe_ret = (void *) 0

	hash_iter_init $arg0

	while $hfe_entry && !$hfe_ret
		gdb_memcmp $hfe_key $hfe_entry_key $hfe_hash->key_size
		if $gdbm_ret == 0
			set $hfe_ret = $hfe_entry
		end
		hash_iter_next
	end
end


##################################
# Function: mds_cache_find_entry #
##################################
#
# Prints a cached MDS entry (basically a fake vnode used to cache MDS block
# contents). When multiple mirrors are present, the lowest baddr is always
# used for caching.
#
# This does a linear search instead of computing the hash, so it might be kind
# of slow on big clusters, since it runs in O(number of drives in the cluster)
# 
# Arguments:
# arg0 - devid of lowest baddr
# arg1 - drive of lowest baddr

define mds_cache_find_entry
	set $mcfe_devid = $arg0
	set $mcfe_drive = $arg1

	hash_iter_init &g_mds_cache->vnodes

	set $mcfe_vnode_entry = (void *) 0
	while $hfe_entry && !$mcfe_vnode_entry
		set $mcfe_entry_key = (struct mds_cache_key *) $hfe_entry_key
		if $mcfe_entry_key->devid == $mcfe_devid && $mcfe_entry_key->drive == $mcfe_drive
			# The off_t cast is an offsetof implementation
			set $mcfe_vnode_entry = (struct mds_cache_vnode *)((const uint8_t *) $hfe_entry - (off_t) &((struct mds_cache_vnode *) 0)->he)
			print *$mcfe_vnode_entry
		end
		hash_iter_next
	end
end

define mds_cache_find_buf
	set $mcfe_baddr = $arg0

	mds_cache_find_entry $mcfe_baddr->devid $mcfe_baddr->drive

	set $mcfe_baddr_bits = ((uint64_t) $mcfe_baddr->_bits1 << 8) | $mcfe_baddr->_bits2
	set $mcfe_baddr_size_mask = 1ULL << (7 >> ($mcfe_baddr_bits & 1)) - 1
	set $mcfe_baddr_offset = ($mcfe_baddr_bits & ~$mcfe_baddr_size_mask) << (6 - 1)
	set $mcfe_baddr_cacheidx = $mcfe_baddr_offset >> 13

	findbuf_in_lists $mcfe_vnode_entry->vnode $mcfe_baddr_cacheidx
end

