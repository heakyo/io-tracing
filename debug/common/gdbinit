#
# Utility function for BSW debugging
#
# Prints a struct safe_write_cmd in an easily-readable format
#
define print_safe_write_cmd
	set $pswc_cmd = $arg0
	printf "struct safe_write_cmd @ %p = ", (void*)$arg0

	init-if-undefined $TARGET_VERSION = osrevision
	if ($TARGET_VERSION < $HABANERO_VERSION)
	  printf "{\n  sw_priority = "
	  output $pswc_cmd->sw_priority
	end
	printf ",\n  sw_cmd = "
	output $pswc_cmd->sw_cmd
	printf ",\n  sw_wait_count = "
	output $pswc_cmd->sw_wait_count
	printf ",\n  sw_swip = "
	output $pswc_cmd->sw_swip
	if ($pswc_cmd->sw_cmd == WC_ABORT)
	  print_sw_abort_cmd $pswc_cmd
	end
	if ($pswc_cmd->sw_cmd == WC_ALLOC)
	  print_sw_alloc_cmd $pswc_cmd
	end
	if ($pswc_cmd->sw_cmd == WC_FEC)
	  print_sw_fec_cmd $pswc_cmd
	end

	if ($pswc_cmd->sw_cmd == WC_READ)
	  print_sw_read_cmd $pswc_cmd
	end
	if ($pswc_cmd->sw_cmd == WC_RECONSTRUCT)
	  print_sw_reconstruct_cmd $pswc_cmd
	end

	if ($pswc_cmd->sw_cmd == WC_WRITE)
	  print_sw_write_cmd $pswc_cmd
	end
	if ($pswc_cmd->sw_cmd == WC_UIOMOVE)
	  print_sw_uiomove_cmd $pswc_cmd
	end
	if ($pswc_cmd->sw_cmd == WC_WRITE_UIO_ZERO)
	  print_sw_write_uio_zero_cmd $pswc_cmd
	end

	if ($TARGET_VERSION >= $HABANERO_VERSION)
	  if ($pswc_cmd->sw_cmd == WC_WRITE_ZERO)
	    printf "WRITE_ZERO"
	  end
	else
	  if ($pswc_cmd->sw_cmd == WC_SETBLKADDRS)
	    print_sw_setblkaddrs_cmd $pswc_cmd
	  end
	  if ($pswc_cmd->sw_cmd == WC_SET_WIDTH_DEVICES)
	    print_sw_set_width_devices_cmd $pswc_cmd
	  end
	  if ($pswc_cmd->sw_cmd == WC_L2_PREFETCH)
	    print_sw_l2_prefetch_cmd $pswc_cmd
	  end
	  if ($pswc_cmd->sw_cmd == WC_IFM_FLUSH_OP)
	    print_sw_ifm_flush_op_cmd $pswc_cmd
	  end
	  if ($pswc_cmd->sw_cmd == WC_WRITE_UIO)
	    print_sw_write_uio_cmd $pswc_cmd
	  end
	  if ($pswc_cmd->sw_cmd == WC_XFER)
	    print_sw_xfer_cmd $pswc_cmd
	  end
	end

	if ($pswc_cmd->sw_cmd == WC_ZERO_READ)
	  print_sw_zero_read_cmd $pswc_cmd
	end

	printf ",\n  sw_waiters = "
	output $pswc_cmd->sw_waiters
	printf ",\n  next = "
	output $pswc_cmd->next
	if ($TARGET_VERSION < $HABANERO_VERSION)
	  printf ",\n  head = "
	  output $pswc_cmd->head
	end
	printf "\n}\n"
end

