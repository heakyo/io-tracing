# The main lock state dump function
define dump_genlk_state
	# Multiplex between different lock domains
	# $arg0 == 1 --> g_lin_lock
	# $arg0 == 2 --> g_mds_block_lock
	# $arg0 == 3 --> g_delete_lock

	set $lin = $arg0 == 1
	set $mds_block = $arg0 == 2
	set $delete = $arg0 == 3

	if ($lin)
	  set $dgs_entries = g_lin_lock.genlk->local->entries
	  set $dgs_waiters = g_lin_lock.genlk->local->waiters
	end
	if ($mds_block)
	  set $dgs_entries = g_mds_block_lock.genlk->local->entries
	  set $dgs_waiters = g_mds_block_lock.genlk->local->waiters
	end
	if ($delete)
	  set $dgs_entries = g_delete_lock.genlk->local->entries
	  set $dgs_waiters = g_delete_lock.genlk->local->waiters
	end

	# NOT ACCURATE - not sure if this is possible to get working, since the clock isn't being updated, the cached value might be incorrect
	set $dgs_current_time = 1000000*(((struct bintime *)&timehands->th_offset).sec) + ((1000000*(((struct bintime *)&timehands->th_offset).frac))>>32)

	# Where does 11 come from?
	# 32 bit
	# PAGE_SHIFT = 13
	# POINTER_SHIFT = 2
	# ISI_HASH_PAGE_SHIFT = PAGE_SHIFT - POINTER_SHIFT = 13 - 2 = 11
	# 64 bit
	# PAGE_SHIFT = 12
	# POINTER_SHIFT = 3
	# ISI_HASH_PAGE_SHIFT = PAGE_SHIFT - POINTER_SHIFT = 12 - 3 = 9

	if (mp_ncpus > 1)
	  set $ISI_HASH_PAGE_SHIFT = 9
	else
	  set $ISI_HASH_PAGE_SHIFT = 11
	end

	# Print owner state from entries hash
	if (($dgs_entries->num_buckets >> $ISI_HASH_PAGE_SHIFT) > 1)
	  set $dgs_page = 0
	  while ($dgs_page < ($dgs_entries->num_buckets >> $ISI_HASH_PAGE_SHIFT))
	    set $dgs_i = 0
	    while ($dgs_i < (1 << $ISI_HASH_PAGE_SHIFT))
 	      if ($dgs_entries.storage.pages[$dgs_page][$dgs_i].slh_first)
	        set $dgs_j = (struct i_lock_entry *)(((uint8_t *)$dgs_entries.storage.pages[$dgs_page][$dgs_i].slh_first) + $dgs_entries->key_offset)
                print_genlk_entry $dgs_j
	      end
	      set $dgs_i = $dgs_i + 1
	    end
	    set $dgs_page = $dgs_page + 1
	  end
	else
	  set $dgs_i = 0
	  while ($dgs_i < $dgs_entries->num_buckets)
	    if ($dgs_entries.storage.chains[$dgs_i].slh_first)
	      set $dgs_j = (struct i_lock_entry *)(((uint8_t *)$dgs_entries.storage.chains[$dgs_i].slh_first) + $dgs_entries->key_offset)
              print_genlk_entry $dgs_j
	    end
	    set $dgs_i = $dgs_i + 1
	  end
	end

	# Print waiter state from waiters list
	set $dgs_i = $dgs_waiters.tqh_first
	while ($dgs_i)
	  print_process_underbar $dgs_i->proc->p_pid
	  print_process_label $dgs_i->proc->p_pid $dgs_i->proc->p_comm
	  if $lin
	    print_lin_underbar $dgs_i
	    print_lin_label $dgs_i
	  end
	  if $mds_block
	    print_mds_block_underbar $dgs_i
	    print_mds_block_label $dgs_i
	  end	
	  if $delete
	    print_delete_underbar $dgs_i
	    print_delete_label $dgs_i
	  end
	  print_process_underbar $dgs_i->proc->p_pid
	  printf "->"

	  if $lin
	    print_lin_underbar $dgs_i
	  end
	  if $mds_block
	    print_mds_block_underbar $dgs_i
	  end	
	  if $delete
	    print_delete_underbar $dgs_i
	  end

	  if ($dgs_i->exclusive)
	    printf " [ label = \"exclusive\\nwaiting:%f\" ];\n", $dgs_current_time - $dgs_i->started
	  else
	    printf " [ label = \"shared\\nwaiting:%f\" ];\n", $dgs_current_time - $dgs_i->started
	  end
