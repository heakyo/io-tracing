# Function: dump_hash #
#######################
#
# Utility function to dump a hash table
#
# Prints all hash table elements
#
# Arguments:
# arg0	-	Pointer to the hash
# arg1	-	Struct name of the things in the hash
# arg2  -	Field name of the hash entry in the struct
#
define dump_slist_hash
	set $buck=$arg0
	set $nb=$arg1
	set $cur=(($arg2)->slh_first)
	set $off = (size_t)(&((struct $arg3 *)0)->$arg4)
	set $n=1
	if ($cur)
		printf "bucket %d/%d:\n", $buck, $nb
		while ($cur && $n < 30000)
			printf "\t%d: ", $n
			output $cur
			printf ": "
			output *((struct $arg3 *)((char *)$cur - $off))
			printf "\n"
			set $n=$n+1
			set $cur=(($cur)->bucket_link.sle_next)
		end
	end
end
document dump_slist_hash
	show a hash slist.  usage: dump_slist head field
end

define dump_hash
	set $h = $arg0
	set $num_buckets = $h->num_buckets
	set $num_entries = $h->num_entries
	set $page_size = vm_cnt.v_page_size
	set $buckpp = $page_size / sizeof(struct isi_hash_chain)
	set $i = 0
	if ($num_buckets / $buckpp > 1)
		while ($i < $num_buckets)
			set $p = $i / $buckpp
			set $off = $i % $buckpp

			dump_slist_hash $i $num_buckets &($h->storage.pages[$p][$off]) $arg1 $arg2

			set $i = $i + 1
		end
        else
		while ($i < $num_buckets)

			dump_slist_hash $i $num_buckets &($h->storage.chains[$i]) $arg1 $arg2

			set $i = $i + 1
		end
        end
end
document dump_hash
	show a hash.  usage: dump_hash hash struct_type struct_field
end

# Find a transaction given the transaction sequence in the node's journal
# $arg0 = jd_trans_seq_t
define journal_find_txn
  set $jft_tr_seq = $arg0 
  set $jft_journal = (struct journal *)((struct ifsmount *)efs_mp->mnt_data)->im_journal
  set $jft_list = 0
  set $jft_found = 0
  while ($jft_list < TR_LIST_NUM && $jft_found == 0)
    set $jft_anchor = $jft_journal->j_txns[$jft_list]
    set $jft_iter = $jft_anchor.tqh_first
    while ($jft_iter)
      #print $jft_iter
      if ($jft_iter->tr_seq.n == $jft_tr_seq.n)
	printf "Found %p in list %d\n", $jft_iter, $jft_list
	set $jft_found = 1
	loop_break
      end
      set $jft_iter = $jft_iter.tr_link.tqe_next
    end
    set $jft_list += 1
  end
end

# Print attributes inlined in the dinode
# arg0: dinode pointer
define print_dinode_attributes
  set $pda_dip = $arg0
  set $pda_start = (const char *)&$pda_dip->di_idi - $pda_dip->di_attr_bytes
  set $pda_cursor = $pda_start
  set $pda_end = $pda_start + $pda_dip->di_attr_bytes
  set $pda_attr_size = 0

  while ($pda_cursor < $pda_end)
    set $pda_record = (struct ifm_attribute_record *)$pda_cursor
    if ($pda_record->key > 0 && $pda_record->key <= INATTR_MAX)
      set $pda_attr = &inattr_def_array[$pda_record->key]
      if ($pda_attr->fixed_len > 0)
	printf "key: %d, attr start: %p, attr size: %d\n", $pda_record->key, \
          $pda_record->data, $pda_attr->fixed_len
