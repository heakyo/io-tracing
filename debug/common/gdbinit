define ntohl
	set $q1=((($arg0) & 0xff)       << 24)
	set $q2=((($arg0) & 0xff00)     << 8)
	set $q3=((($arg0) & 0xff0000)   >> 8)
	set $q4=((($arg0) & 0xff000000) >> 24)
	print $q1|$q2|$q3|$q4
end
document ntohl
	Prints out the argument byteswapped
end

define printaddr
	set $q1=((($arg0) & 0xff)       >> 0)
	set $q2=((($arg0) & 0xff00)     >> 8)
	set $q3=((($arg0) & 0xff0000)   >> 16)
	set $q4=((($arg0) & 0xff000000) >> 24)
	printf "%d.%d.%d.%d\n",$q1,$q2,$q3,$q4
end
document printaddr
	Prints out provided network-order integer in dotted-quad
end

define sc_lookup
	set $wchan=$arg0
	set $hash=(((uintptr_t)($wchan) >> 8) & 127)
	set $sq=sleepq_chains[$hash].sc_queues.lh_first
	while ($sq != 0 && $sq->sq_wchan != $wchan)
		set $sq = $sq->sq_hash.le_next
	end
	print $sq
end
document sc_lookup
	Prints the sleepq for a given wchan
end

define check_swatchdog
    set $size = sizeof(swatch_cpu_state)/sizeof(swatch_cpu_state[0])-1 

    printf "CPU states:\n"
    while ( $size >= 0)
        set $cpu = swatch_cpu_state[$size]
        if ($cpu.ticks != 0 || $cpu.generation != 0)
            printf "CPU: %d\tthread: %llx\twarnings: %d\tticks: %d\tgeneration: %u\tstate:%d\n", \
                $size, $cpu.td, $cpu.num_warnings, $cpu.ticks, $cpu.generation, $cpu.td.td_state
        end
        set $size = $size - 1
    end

    set $su = swatch_userspace
    printf "CPU 0 - US starvation:\n"
    printf "\tthread: %llx\twarnings: %d\tticks: %d\tgeneration: %u\n", $su.td, \
        $su.num_warnings, $su.ticks, $su.generation

end
document check_swatchdog
    show cpu states to find the cpu hog that caused to panic.
    ref:src/sys/kern/isi_swatchdog.c
end

