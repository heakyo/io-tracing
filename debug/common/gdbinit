#############################
# Function: find_lock_entry #
#############################
#
# Prints a struct lock_entry (genlk_local.c version) for a particular
# genlk lock. This only works for 8-byte keys (lins, baddrs), which means
# it works with the linlock, mdsblocklock, and delete lock domains.
#
# Arguments:
# arg0 - a pointer to a struct genlk_local
# arg1 - the resource (LIN or baddr) represented as a 64-bit unsigned integer
# 
# Prints all lock_entries associated with the resource. There should be zero or
# one entries, pass it as an argument to print_lock_owners to see which
# thread(s) on the local node own the lock. If print_lock_owners doesn't output
# anything, then the lock is lazy.

define find_lock_entry
	set $fle_genlk = $arg0
	set $fle_gl = $fle_genlk->local
	set $fle_gle = $fle_gl->entries
	set $fle_resource = $arg1

	# compute the hash bucket
        set $ih8_key_ptr = (u_int8_t *) &$arg1
        set $ih8_a = (u_int32_t) 0x9e3779b9
        set $ih8_b = (u_int32_t) 0x9e3779b9
        set $ih8_c = (u_int32_t) 0
        set $ih8_a = (u_int32_t) $ih8_a + *(const u_int32_t *) &$ih8_key_ptr[0]
        set $ih8_b = (u_int32_t) $ih8_b + *(const u_int32_t *) &$ih8_key_ptr[4]

	# do the mix(a,b,c)
        set $ih8_a = $ih8_a - $ih8_b
        set $ih8_a = $ih8_a - $ih8_c
        set $ih8_a = $ih8_a ^ ($ih8_c >> 13)

	set $ih8_b = $ih8_b - $ih8_c
        set $ih8_b = $ih8_b - $ih8_a
        set $ih8_b = $ih8_b ^ ($ih8_a << 8)

	set $ih8_c = $ih8_c - $ih8_a
        set $ih8_c = $ih8_c - $ih8_b
        set $ih8_c = $ih8_c ^ ($ih8_b >> 13)

	set $ih8_a = $ih8_a - $ih8_b
        set $ih8_a = $ih8_a - $ih8_c
        set $ih8_a = $ih8_a ^ ($ih8_c >> 12)

	set $ih8_b = $ih8_b - $ih8_c
        set $ih8_b = $ih8_b - $ih8_a
        set $ih8_b = $ih8_b ^ ($ih8_a << 16)

	set $ih8_c = $ih8_c - $ih8_a
        set $ih8_c = $ih8_c - $ih8_b
        set $ih8_c = $ih8_c ^ ($ih8_b >> 5)

	set $ih8_a = $ih8_a - $ih8_b
        set $ih8_a = $ih8_a - $ih8_c
        set $ih8_a = $ih8_a ^ ($ih8_c >> 3)

	set $ih8_b = $ih8_b - $ih8_c
        set $ih8_b = $ih8_b - $ih8_a
        set $ih8_b = $ih8_b ^ ($ih8_a << 10)

	set $ih8_c = $ih8_c - $ih8_a
        set $ih8_c = $ih8_c - $ih8_b
        set $ih8_c = $ih8_c ^ ($ih8_b >> 15)

	set $fle_offset = $ih8_c & ($fle_gle->num_buckets - 1)
	set $fle_bi = 0
	while ($fle_bi < $fle_gle->num_buckets)
	  set $fle_i = ($fle_bi + $fle_offset) % $fle_gle->num_buckets
	  set $fle_he = $fle_gle->buckets[$fle_i]->slh_first
	  while ($fle_he != 0)
	    set $fle_entry = (struct lock_entry*)(((char*)$fle_he)-8)
	    # printf "resource = %llu\n", $fle_entry->resource
	    if ($fle_entry->resource == $fle_resource)
	      output $fle_entry
	      printf "\n"
	      set $fle_he = 0
	      set $fle_bi = $fle_gle->num_buckets
	    else
	      set $fle_he = $fle_he->bucket_link->sle_next
	    end
	  end
	  set $fle_bi = $fle_bi + 1
	end
end

# A slow O(n) search for a particular lazy lock in a genlk domain. This can be
# EXTREMELY slow when lots of lazy locks are present (20 minutes+), and the
# find_lock_entry function should probably be used instead.

define find_lazy_lock
	set $fll_genlk = $arg0
	set $fll_resource = $arg1
	set $fll_lock_entry = $fll_genlk->local->lazy_locks->tqh_first
	while ($fll_lock_entry != 0)
	  # printf "resource = %llu\n", $fll_lock_entry->resource
	  if ($fll_lock_entry->resource == $fll_resource)
	    output $fll_lock_entry
	    printf "\n"
	  end
	  set $fll_lock_entry = $fll_lock_entry->lazy_queue_link->tqe_next
	end
end

