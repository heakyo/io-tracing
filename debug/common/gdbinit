# Show memory usage for all malloc pools
# $arg0 == output mask
# 0x01 - do not prune empty entries
# 0x10 - do not include negative values in total usage
#	 see comment in get_malloc_pigs
define showmallocpools
        set $smp_mtp=kmemstatistics
        set $smp_total=0
        set print address off
        while ($smp_mtp)
		set $smp_stat=(struct malloc_type_internal*)$smp_mtp->ks_handle
		set $smp_cpu=0
		set $smp_memuse=(int64_t)0
		while ($smp_cpu < 16)
		  	if ((all_cpus & (1 << $smp_cpu)))
				set $smp_memuse+=(int64_t)$smp_stat->mti_stats[$smp_cpu].mts_memalloced
				set $smp_memuse-=(int64_t)$smp_stat->mti_stats[$smp_cpu].mts_memfreed
			end
			set $smp_cpu+=1
		end
		if ($smp_memuse || ($arg0 & 0x01))
			printf "%s: %lld\n", $smp_mtp->ks_shortdesc, $smp_memuse
			if ($smp_memuse > 0 || !($arg0 & 0x10))
				set $smp_total+=$smp_memuse
			end
		end
                set $smp_mtp=$smp_mtp->ks_next
        end
        echo Total:\ 
        output $smp_total
        echo \n
        set print address on
end

