#    A note about scoping in gdb script functions    #
######################################################
#
# All variables in this file, even ones declared in functions, are global.
# This means that naming collisions can occur, and lead to unexpected
# consequences in your scripts. It's recommended to prefix variable names
# declared inside functions with some unique prefix. One way to do it is 
# to come up with an acronym for the function name, and prefix all variable
# names in that function with it. For example, all "local" variables declared
# in print_uipc_client are prefixed with "puc".


#############################################################
#    A note about script compatibility for released version #
#############################################################
#
# Very often due to change of code between releases, the user
# defined commands (scripts) may also need to change. But throwing
# away old script is not good since developer often has need to
# triage issues reported on old released product. Thus it is very
# helpful to keep a working copy of original script while changing
# it to work with current version.
#
# To achieve that, we shall follow some basic conventions.
#
# 1. If this is a new command definition, which doesn't work
#    for past releases, then we can print out minimum supported
#    version in the command's document. E.g.
#
#          printf "only works after JAWS_7111 \n"
#
# 2. Similarly, if an existing command definition doesn't work
#    for current / future release, then we can print out maximum
#    reversion supported in the command's document. E.g.
#
#          printf "only works prior to JAWS_7111 \n"
#
# 3. If existing command definition needs to be modified (assuming
#    current OneFS revision is MOBY_VERSION), then we can do something
#    simple as below:
#
#       ## above is common script
#
#       if (osrevision < $MOBY_VERSION)
#             ... old script ...
#       else
#             ... new script ...
#
#       ## after is common script
#
#     if it makes sense, we can also move old or new script to a
#     separate routines and invoke them here
#

#
# constants of released versions
#
define init_version_numbers
        set $HABANERO_VERSION =      0x600000000000000L
        set $CHOPU_VERSION =         0x605000000000000L
        set $MAVERICKS_VERSION =     0x700000000000000L
        set $MAVERICKS_701_VERSION = 0x700010000000000L
        set $MAVERICKS_702_VERSION = 0x700020000000000L
        set $WAIKIKI_VERSION =       0x701000000000000L
        set $JAWS_VERSION =          0x701010000000000L
        set $JAWS_7111_VERSION =     0x701015000100000L
        set $MOBY_VERSION =          0x702000000000000L
        set $RIPTIDE_VERSION =       0x800000000000000L
end

init_version_numbers

###########################################
#    A note about kernel debug symbols    #
###########################################
#
# The easiest way to get your kernel symbols to work correctly is the following:
#
# First, for official builds (i.e. b.4444r):
# 
# 1. Find all debug symbol files in the build's object tree. For drivers, these
#   look like "<driver_name>.ko.debug". For the kernel, its just "kernel.debug".
#   Object trees for a particular build can be found at
#   leetbiox:/ifs/builds/<build_name>/obj/kernel.<arch>/build/src
#
# 2. Copy said files into a symbols directory (probably named after the
# build number + arch).
#
# 3. Strip off the .debug extension from all symbol files
#
# The above 3 steps can be accomplished by a fairly simple shell script,
# which I leave as an exercise to the reader :)
#
# 4. Run 'gdb kernel' from the directory and make sure your .gdbinit contains
# the line 'set solib-search-path .'
#
# The process is similar for builds you compile yourself, except the object
# files reside in your SVN tree at <branch>/obj/kernel.<arch>.
#
# Unfortunately, at the time of this writing (04/23/2008) things don't work
# quite so well for 64-bit builds. In particular, the line
# 'set solib-search-path .' fails to properly load symbols for drivers (kernel
# symbols work fine). There is a work-around that kind of works for efs.ko, but
# doesn't get everything loaded properly. The work-around is to use the
# load_efs_ko function defined below.

set solib-search-path .

# Function: load_efs_ko
#
# Loads efs.ko symbol file for 64-bit debugging. Does not seem to properly load
# addresses of some (all?) global structs / variables, for example g_gmp_info.
# This makes it impossible to examine their contents. But at least, this lets
# us look at stacks, function arguments, and local variables.

define load_efs_ko
	add-symbol-file ./efs.ko efs_ko_text_start
end



