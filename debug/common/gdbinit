define gd_show_bh_anchor
	set $_anchor = bh_anchor
	set $_bh = $_anchor.tqh_first

	if (!$_bh)
		printf "bh_anchor is empty!\n"
		return
	end
	
	printf "Block Heap ..... \n"
	printf "name\t\t blksz\t count\t pool\n"
	while ($_bh)
		printf "%s\t %zu\t %zu\t %p\n", \
			$_bh->name, $_bh->blksz, $_bh->count ,$_bh->pool

		set $_bp = $_bh->pool
		while ($_bp)
			printf "  |--bp->%p(next)---%zu(count)---%p(memptr)\n", \
				$_bp->next, $_bp->count, $_bp->memptr
			set $_bp = $_bp->next
		end

		set $_bh = $_bh->heaps.tqe_next
	end
end

define _gd_show_vm_freelist
	set $_fq = (struct vm_freelist (*)[2][13])$arg0
	set $_j = 0
	set $_k = 0

	#printf "%p\n", vm_phys_free_queues[0][0]
	#printf "%p\n", $_fq

	while ($_j < 2)

		set $_k = 0
		printf "  |--%d\n", $_j

		while ($_k < 13)
			printf "  |--%d-%d(pl-od)->%d(lcnt)\n", $_j, $_k, \
				(*$_fq)[$_j][$_k].lcnt
			set $_k = $_k + 1
		end

		printf "  |-------------------\n",
		set $_j = $_j + 1
	end
end

define gd_show_vm_phys_segs
	set $_i = 0

	printf "VM PHYS NSEGS: %d\n", vm_phys_nsegs
	printf "Index\t start\t\t end\t\t domain\t first_page\t free_queues\n"
	while ($_i < vm_phys_nsegs)

		printf "seg[%d]:\t %p\t %p\t %d\t %p\t %p\n", \
			$_i, vm_phys_segs[$_i].start, vm_phys_segs[$_i].end, \
			vm_phys_segs[$_i].domain, vm_phys_segs[$_i].first_page, \
			vm_phys_segs[$_i].free_queues

		_gd_show_vm_freelist vm_phys_segs[$_i].free_queues

		set $_i = $_i + 1
	end
end

