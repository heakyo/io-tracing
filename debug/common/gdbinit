#
# Like showmallocpools, but for all UMA zones
#
define showumapools_before_riptide
       set $sup_umak=uma_kegs->lh_first
       set $sup_totalused = 0
       while ($sup_umak)
	     showumakeg_before_riptide $sup_umak
	     set $sup_umak=$sup_umak->uk_link->le_next
       end
       printf "Total UMA memory usage: %ld bytes\n", $sup_totalused
end

#
# Helper function for showumapools (for RIPTIDE)
#
define showumakeg
	set $suz_ukeg=$arg0

	set $suz_umazone = $suz_ukeg->uk_zones->lh_first
	while ($suz_umazone)
	    set $suz_cachefree = 0
	    if (($suz_ukeg->uk_flags & 0x2000) == 0)
	      set $suz_cpu = 0
	      while ($suz_cpu <= mp_maxid)
	        # CPU_SETSIZE=128 bits, BITSET_BITS = sizeof(long)*8, BITSET_WORDS=128/(8*8)=2
	        set $suz_cpu_bitset_bits = sizeof(long)*8
	        set $suz_cpu_bitset_word = $suz_cpu/$suz_cpu_bitset_bits
	        if (all_cpus.__bits[$suz_cpu_bitset_word] & (1 << ($suz_cpu)) != 0)
	          set $suz_cache = &($suz_umazone->uz_cpu[$suz_cpu])
	          if ($suz_cache->uc_allocbucket)
	            set $suz_cachefree = $suz_cachefree + $suz_cache->uc_allocbucket->ub_cnt
		  end
	          if ($suz_cache->uc_freebucket)
		    set $suz_cachefree = $suz_cachefree + $suz_cache->uc_freebucket->ub_cnt
	          end
	          set $suz_cpu = $suz_cpu + 1
	        end
	      end
	    end
	    set $suz_bucket = $suz_umazone->uz_buckets->lh_first
	    while ($suz_bucket)
	      set $suz_cachefree = $suz_cachefree + $suz_bucket->ub_cnt
	      set $suz_bucket = $suz_bucket->ub_link->le_next
	    end

	    set $suz_totalfree = $suz_ukeg->uk_free + $suz_cachefree
	    set $suz_totalused = ($suz_ukeg->uk_ipers * ($suz_ukeg->uk_pages / $suz_ukeg->uk_ppera)) - $suz_totalfree
	    set $suz_totalfree = $suz_totalfree * $suz_ukeg->uk_rsize
	    set $suz_totalused = $suz_totalused * $suz_ukeg->uk_rsize
	    set $sup_totalused = $sup_totalused + $suz_totalused

	    printf "%31s,  %p,%9ld,%9ld,%9ld\n", $suz_umazone->uz_name, $suz_umazone, $suz_totalused, $suz_totalfree, $suz_umazone->uz_size

	    set $suz_umazone = $suz_umazone->uz_link->le_next
       end
end

