define add_modules
  python
## Start of Python Script ##
module = gdb.lookup_symbol("linker_files")[0].value()['tqh_first']

# Traverse Module List Skipping the First (kernel)
while module.dereference()['link']['tqe_next'] != 0:

  module = module.dereference()['link']['tqe_next']
  elf = module.cast(gdb.lookup_type("elf_file_t")).dereference()
  progtab = elf['progtab']
  e_shdr = elf['e_shdr']

  filename = module['filename'].string()
  dottext = ""
  others = []

  # Just filter the modules you don't need
  #if filename != "efs.ko" and filename != "idxd.ko":
    #continue

  # Traverse each ELF section
  for i in xrange(elf['nprogtab']):
    curprogtab = progtab[i]
    addr = curprogtab['addr']
    name = curprogtab['name'].string()
    sec = curprogtab['sec']
    sh_flags = e_shdr[sec]['sh_flags']

    # Check is a symbol table
    if sh_flags & 2 == 2: # SHT_SYMTAB
      if name == ".text":
        dottext = addr
      elif addr:
        others.append("-s %s %s " % (name, addr))

  # Add resulting symbol file to gdb
  finalcmd = "add-symbol-file %s %s %s" % (filename, dottext, ''.join(others))
  print("finalcmd:%s" % (finalcmd))
  gdb.execute(finalcmd)
## End of Python Script ##
  end
end

