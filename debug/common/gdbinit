# This uses array indexing instead of pointer dereference so it works
# with literals passed in on the gdb command line.
define strcmp
  set $mysc_v1 = $arg0
  set $mysc_v2 = $arg1
  set $mysc_idx = 0
  while 1
    if $mysc_v1[$mysc_idx] != $mysc_v2[$mysc_idx]
      set $strcmp_ret = ((int) $mysc_v1[$mysc_idx]) - ((int) $mysc_v2[$mysc_idx])
      loop_break
    end
    if !$mysc_v1[$mysc_idx]
      set $strcmp_ret = 0
      loop_break
    end
    set $mysc_idx = $mysc_idx + 1
  end
end
document strcmp
	This is the usual C library function strcmp(), implemented as
	a gdb script. It can handle strings constructed as arrays on
	the console as well as strings in the program being debugged.
end

