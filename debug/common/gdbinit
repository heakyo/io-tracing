# findbuf_inhash - Look up a buf for a given sector / drv:
#   $arg0 = sector
#   $arg1 = drv
define findbuf_inhash
   set $HASH_MASK = (0xfffffe0)
   set $BX_BKGRDMARKER = (0x00000020)

   set $bh = bufhash
   set $sector = (daddr_t)$arg0
   set $bo = &($arg1->drv_devvp->v_bufobj)
     # Find the index into the hashtable
   if (!$bo->bo_buf_hash_cache.valid || ($sector & $HASH_MASK) != \
       ($bo->bo_buf_hash_cache.blkno & $HASH_MASK))
       set $base = ((u_int32_t)$bo ^ ((u_int32_t)$sector & $HASH_MASK))
   else
       set $base = $bo->bo_buf_hash_cache.base
   end

   set $index = ($base + ($sector & ~$HASH_MASK)) & bufhashmask
   printf "index = %d\t", $index

   # Lookup the buf in the hashtable
   set $bp = (struct buf *)(bufhash[$index].lh_first)
   while ($bp != 0 && $bp->b_bufobj != $bo || $bp->b_lblkno != $sector || \
       ($bp->b_xflags & $BX_BKGRDMARKER))
       set $bp = $bp->b_hashnext.le_next
   end

   printf "bp = %p\n", $bp
end 

