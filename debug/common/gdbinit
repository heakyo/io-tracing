# Helper for print_cmds_graph
#

define print_baddr_pre_habanero
	set $pb_addr = (struct ifs_addr*)$arg0
	printf "%d,", $pb_addr->devid
	printf "%d,", $pb_addr->drive

	set $pb_bits = ($pb_addr->bits1 << 8) | $pb_addr->bits2
	set $pb_size = 512
	if ($pb_addr->bits2 == 0)
	  set $pb_size = 8192
	end
	set $pb_bits = $pb_bits & (~(((u_int64_t)$pb_size - 1) >> 6))
	set $pb_offset = (u_int64_t)($pb_bits << 5)
	printf "%llu:", $pb_offset
	printf "%d", $pb_size
end

