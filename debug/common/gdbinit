#
# Outputs the in-memory graph of all GEOM structures, in dotty format.
# Copy/paste into a .dot file and run dotty to generate the graph.
#
define make_geom_graph
       set $reffed_only = $arg0
       printf "digraph \"geom\" { \n" 
       set $geom_class = g_classes->lh_first
       while ($geom_class)
	 set $geom = $geom_class->geom->lh_first
	 while ($geom)
	   set $reffed = 0
	   set $geom_reffed = 0
	   set $pp = $geom->provider->lh_first
	   while ($pp)
	     if ($pp->acr != 0 || $pp->acw != 0|| $pp->ace != 0)
	       set $reffed = 1
	       set $geom_reffed = 1
	     else
	       set $reffed = 0
	     end
	     if (!$reffed_only || $reffed)
	       print_g_provider $pp
             end
	     set $pp = $pp->provider->le_next
	   end
	   set $cp = $geom->consumer->lh_first
	   set $cpi = 0
	   while ($cp)
	     if ($cp->acr != 0 || $cp->acw != 0 || $cp->ace != 0)
	       set $reffed = 1
	       set $geom_reffed = 1
	     else
	       set $reffed = 0
	     end
	     if (!$reffed_only || $reffed)
	       print_g_consumer $cp $cpi
	     end
	     set $cpi = $cpi + 1
	     set $cp = $cp->consumer->le_next
	   end
	   if (!$reffed_only || $geom_reffed)
	     print_g_geom $geom
	   end
	   set $geom = $geom->geom->le_next
	 end
	 set $geom_class = $geom_class->class->le_next
       end
       printf "}\n"
end

#
# Helper function for showumapools
#
define showumazone_before_riptide
       set $suz_umazone=$arg0
       set $suz_ukeg = $suz_umazone->uz_keg
       if ($suz_umazone)
	  set $suz_cachefree = 0
	  if (($suz_ukeg->uk_flags & 0x2000) == 0)
	     set $suz_cpu = 0
	     while ($suz_cpu <= mp_maxid)
		   if ((all_cpus & (1 << ($suz_cpu))) != 0)
		      set $suz_cache = &($suz_umazone->uz_cpu[$suz_cpu])
		      if ($suz_cache->uc_allocbucket)
			 set $suz_cachefree = $suz_cachefree + $suz_cache->uc_allocbucket->ub_cnt
		      end
		      if ($suz_cache->uc_freebucket)
			 set $suz_cachefree = $suz_cachefree + $suz_cache->uc_freebucket->ub_cnt
		      end
		      set $suz_cpu = $suz_cpu + 1
		   end
	     end
	  end
	  set $suz_bucket = $suz_umazone->uz_full_bucket->lh_first
	  while ($suz_bucket)
		set $suz_cachefree = $suz_cachefree + $suz_bucket->ub_cnt
		set $suz_bucket = $suz_bucket->ub_link->le_next
	  end
	  set $suz_totalfree = $suz_ukeg->uk_free + $suz_cachefree
	  set $suz_totalused = ($suz_ukeg->uk_ipers * ($suz_ukeg->uk_pages / $suz_ukeg->uk_ppera)) - $suz_totalfree
	  set $suz_totalfree = $suz_totalfree * $suz_ukeg->uk_rsize
	  set $suz_totalused = $suz_totalused * $suz_ukeg->uk_rsize
	  printf "UMA Zone \"%s\" at %p mem used: %ld mem free: %ld\n", $suz_umazone->uz_name, $suz_umazone, $suz_totalused, $suz_totalfree
       end
end
