# This test has two functions. The only difference is we need to pass different parameter to the program main
# 1. Show the function bufdone_finish where the flag B_CACHE is set in the buf struct
## ./rhw_getpages.d -c './main -r'
# call pread
make rhw_getpages

# 2. Show the backtrace of how getpages works
# The key step is we need to remount the file system where the test files are included.
## ./rhw_getpages.d -c './main -s
# call sys_map
make rhw_getpages

# 3. how to check the filesystem the system is using is UFS2
ffs_valloc // sys/ufs/ffs/ffs_alloc.c
-> fs->fs_magic == FS_UFS2_MAGIC
dtrace -n 'ffs_valloc:entry {this->pvp = args[0]; this->pip=(struct inode*)this->pvp->v_data; this->ump=this->pip->i_ump; this->fs=this->ump->um_fs;printf("0x%x", this->fs->fs_magic);}' -c 'mount /dev/ada0p19 mnt' && umount mnt
-------------------------------------------------------------------------
dtrace: description 'ffs_valloc:entry ' matched 1 probe
dtrace: pid 88254 has exited
CPU     ID                    FUNCTION:NAME
 21 117485                 ffs_valloc:entry 0x19540119

As we can see, the result of the command equals the value of FS_UFS2_MAGIC(0x19540119)--sys/ufs/ffs/fs.h
