# Jenkins Skill Configuration
# Copy this file to .env and fill in your credentials.
# Supports multiple Jenkins servers: use _1, _2, _3 suffixes.

# Server 1 (primary)
JENKINS_URL_1=https://your-jenkins-server.example.com
JENKINS_USER_1=your-username
JENKINS_TOKEN_1=your-api-token

# Server 2 (optional)
# JENKINS_URL_2=https://another-jenkins.example.com
# JENKINS_USER_2=another-user
# JENKINS_TOKEN_2=another-token

# SSL verification (set to false for self-signed certs)
JENKINS_SSL_VERIFY=false
